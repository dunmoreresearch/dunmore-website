/* ============================================================
   DUNMORE RESEARCH — stylesheet
   dunmoreresearch.com
   ============================================================ */

/* ── GOOGLE FONTS ── */
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,200;0,9..40,300;0,9..40,400;1,9..40,200&family=DM+Mono:wght@300;400&display=swap');

/* ── RESET ── */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ── TOKENS ── */
:root {
  --black:      #0f0f0e;
  --deep:       #161615;
  --charcoal:   #1e1e1c;
  --stone:      #2c2c2a;
  --ash:        #646460;
  --silver:     #9e9b95;
  --linen:      #eeebe5;
  --white:      #f8f5f0;
  --brass:      #c8a96e;
  --brass-dim:  #8a7248;
  --brass-dark: #4a3d25;

  --font-sans:  'DM Sans', system-ui, sans-serif;
  --font-mono:  'DM Mono', 'Courier New', monospace;

  --fs-display: clamp(2.8rem, 6.5vw, 5.5rem);
  --fs-h2:      clamp(1.8rem, 3.5vw, 3rem);
  --fs-h3:      clamp(1.1rem, 2vw, 1.5rem);
  --fs-body:    clamp(0.82rem, 1.1vw, 0.95rem);
  --fs-small:   0.72rem;
  --fs-label:   0.6rem;

  --track-base: 0.04em;
  --track-wide: 0.2em;
  --track-xl:   0.38em;

  --max-w:      1100px;
  --pad-x:      clamp(1.5rem, 5vw, 4rem);
  --pad-section: clamp(5rem, 10vw, 9rem);

  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
  --ease-out:    cubic-bezier(0, 0, 0.2, 1);
}

/* ── BASE ── */
html {
  scroll-behavior: smooth;
  font-size: 16px;
}

body {
  background-color: var(--black);
  color: var(--linen);
  font-family: var(--font-sans);
  font-weight: 300;
  font-size: var(--fs-body);
  line-height: 1.75;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
}

img, svg { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }

/* ── GRAIN TEXTURE ── */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 1000;
  opacity: 0.028;
  background-image:
    url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px;
}

/* ── LAYOUT ── */
.wrap {
  max-width: var(--max-w);
  margin: 0 auto;
  padding-left: var(--pad-x);
  padding-right: var(--pad-x);
}

/* ── MARK COMPONENT ── */
.mark {
  display: flex;
  flex-direction: column;
  gap: 5px;
  flex-shrink: 0;
}
.mark__bar {
  display: block;
  height: 4px;
  border-radius: 1.5px;
  background: var(--linen);
  transition: width 0.4s var(--ease-smooth), opacity 0.4s;
}
.mark__bar:nth-child(1) { width: 32px; opacity: 1;    }
.mark__bar:nth-child(2) { width: 32px; opacity: 0.48; }
.mark__bar:nth-child(3) { width: 21px; opacity: 0.2;  }

/* ── NAVIGATION ── */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 500;
  padding: 1.6rem var(--pad-x);
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background 0.5s var(--ease-smooth), backdrop-filter 0.5s;
}

.nav--scrolled {
  background: rgba(15, 15, 14, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--stone);
}

.nav__brand {
  display: flex;
  align-items: center;
  gap: 0.9rem;
}

.nav__wordmark {
  display: flex;
  flex-direction: column;
  gap: 1px;
  line-height: 1;
}

.nav__name {
  font-family: var(--font-sans);
  font-weight: 400;
  font-size: 0.78rem;
  letter-spacing: var(--track-wide);
  color: var(--linen);
}

.nav__sub {
  font-family: var(--font-sans);
  font-weight: 200;
  font-size: 0.46rem;
  letter-spacing: var(--track-xl);
  color: var(--ash);
}

.nav__links {
  display: flex;
  align-items: center;
  gap: 2.5rem;
}

.nav__link {
  font-size: var(--fs-label);
  font-weight: 400;
  letter-spacing: var(--track-wide);
  color: var(--ash);
  text-transform: uppercase;
  transition: color 0.25s;
  position: relative;
}

.nav__link::after {
  content: '';
  position: absolute;
  bottom: -3px;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--brass);
  transition: width 0.3s var(--ease-smooth);
}

.nav__link:hover { color: var(--linen); }
.nav__link:hover::after { width: 100%; }

.nav__link--cta {
  color: var(--brass);
  border: 1px solid var(--brass-dark);
  padding: 0.45rem 1.1rem;
  transition: background 0.25s, color 0.25s, border-color 0.25s;
}

.nav__link--cta::after { display: none; }

.nav__link--cta:hover {
  background: var(--brass);
  color: var(--black);
  border-color: var(--brass);
}

/* ── HERO ── */
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.hero__bg {
  position: absolute;
  inset: 0;
  background-image: url('../images/hero-bg.svg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  opacity: 0.9;
}

.hero__bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(15,15,14,0.75) 0%,
    rgba(15,15,14,0.3) 60%,
    rgba(15,15,14,0.85) 100%
  );
}

.hero__content {
  position: relative;
  z-index: 2;
  padding-top: 8rem;
  padding-bottom: 6rem;
  max-width: 780px;
}

.hero__eyebrow {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2.2rem;
}

.hero__eyebrow-rule {
  width: 36px;
  height: 1px;
  background: var(--brass);
  flex-shrink: 0;
}

.hero__eyebrow-text {
  font-family: var(--font-mono);
  font-size: var(--fs-label);
  letter-spacing: var(--track-xl);
  color: var(--brass);
  text-transform: uppercase;
}

.hero__headline {
  font-family: var(--font-sans);
  font-weight: 200;
  font-size: var(--fs-display);
  line-height: 1.06;
  letter-spacing: -0.02em;
  color: var(--white);
  margin-bottom: 2rem;
}

.hero__headline em {
  font-style: normal;
  color: var(--silver);
  font-weight: 200;
}

.hero__body {
  font-size: var(--fs-body);
  font-weight: 300;
  color: var(--silver);
  max-width: 500px;
  line-height: 1.85;
  margin-bottom: 3rem;
}

.hero__actions {
  display: flex;
  align-items: center;
  gap: 2rem;
  flex-wrap: wrap;
}

/* ── BUTTONS ── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-sans);
  font-weight: 400;
  font-size: var(--fs-label);
  letter-spacing: var(--track-wide);
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.3s var(--ease-smooth);
}

.btn--primary {
  background: var(--brass);
  color: var(--black);
  padding: 0.9rem 2.2rem;
}

.btn--primary:hover {
  background: var(--white);
}

.btn--ghost {
  color: var(--ash);
  border-bottom: 1px solid transparent;
  padding-bottom: 1px;
}

.btn--ghost:hover {
  color: var(--linen);
  border-bottom-color: var(--ash);
}

/* ── SCROLL INDICATOR ── */
.hero__scroll {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.6rem;
  z-index: 2;
  animation: fadeIn 2s var(--ease-out) forwards 1.5s;
  opacity: 0;
}

.hero__scroll-text {
  font-family: var(--font-mono);
  font-size: 0.5rem;
  letter-spacing: var(--track-xl);
  color: var(--ash);
  text-transform: uppercase;
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  height: 60px;
}

.hero__scroll-dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--brass);
  animation: pulse 2s ease-in-out infinite;
}

/* ── SECTION DIVIDER ── */
.divider {
  height: 1px;
  background: linear-gradient(to right, transparent 0%, var(--stone) 20%, var(--stone) 80%, transparent 100%);
}

/* ── SECTION SHARED ── */
.section {
  padding-top: var(--pad-section);
  padding-bottom: var(--pad-section);
}

.section__label {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-family: var(--font-mono);
  font-size: var(--fs-label);
  letter-spacing: var(--track-xl);
  color: var(--ash);
  text-transform: uppercase;
  margin-bottom: 3.5rem;
}

.section__label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--stone);
  max-width: 80px;
}

/* ── SERVICES ── */
.services {
  background-color: var(--black);
  position: relative;
}

.services__bg {
  position: absolute;
  inset: 0;
  background-image: url('../images/topo.svg');
  background-size: cover;
  background-position: center;
  opacity: 0.35;
  pointer-events: none;
}

.services__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 1px solid var(--stone);
  position: relative;
  z-index: 1;
}

.service-card {
  padding: 2.8rem 2.2rem 3rem;
  border-right: 1px solid var(--stone);
  position: relative;
  transition: background 0.4s var(--ease-smooth);
  overflow: hidden;
}

.service-card:last-child { border-right: none; }

.service-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 2px;
  height: 0;
  background: var(--brass);
  transition: height 0.5s var(--ease-smooth);
}

.service-card:hover {
  background: var(--charcoal);
}

.service-card:hover::before {
  height: 100%;
}

.service-card__num {
  font-family: var(--font-mono);
  font-size: 0.52rem;
  letter-spacing: var(--track-xl);
  color: var(--brass-dim);
  margin-bottom: 1.4rem;
  display: block;
}

.service-card__title {
  font-family: var(--font-sans);
  font-weight: 300;
  font-size: clamp(1.1rem, 2vw, 1.45rem);
  letter-spacing: -0.01em;
  color: var(--linen);
  margin-bottom: 1.1rem;
  line-height: 1.25;
}

.service-card__desc {
  font-size: 0.8rem;
  font-weight: 300;
  color: var(--ash);
  line-height: 1.85;
}

/* ── ABOUT / POSITIONING ── */
.about {
  background-color: var(--deep);
}

.about__inner {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: clamp(3rem, 6vw, 6rem);
  align-items: start;
}

.about__left {
  position: sticky;
  top: 6rem;
}

.about__mark-wrap {
  margin-bottom: 2rem;
}

.about__mark-label {
  font-family: var(--font-mono);
  font-size: 0.52rem;
  letter-spacing: var(--track-xl);
  color: var(--ash);
  text-transform: uppercase;
  line-height: 2.2;
}

.about__right {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.about__image-wrap {
  position: relative;
  margin-bottom: 2.5rem;
  overflow: hidden;
}

.about__image-wrap img {
  width: 100%;
  height: 280px;
  object-fit: cover;
  filter: grayscale(20%) brightness(0.85);
  transition: filter 0.5s, transform 0.6s var(--ease-smooth);
}

.about__image-wrap:hover img {
  filter: grayscale(0%) brightness(0.95);
  transform: scale(1.02);
}

.about__text p {
  font-size: clamp(0.9rem, 1.4vw, 1.1rem);
  font-weight: 300;
  color: var(--silver);
  line-height: 1.85;
  margin-bottom: 1.6rem;
}

.about__text p strong {
  color: var(--linen);
  font-weight: 400;
}

.about__text p:last-child { margin-bottom: 0; }

/* ── CONTACT ── */
.contact {
  background-color: var(--black);
  border-top: 1px solid var(--stone);
  position: relative;
  overflow: hidden;
}

.contact__bg {
  position: absolute;
  right: -100px;
  top: 50%;
  transform: translateY(-50%);
  width: 600px;
  height: 600px;
  opacity: 0.18;
  pointer-events: none;
}

.contact__inner {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(3rem, 6vw, 6rem);
  align-items: end;
}

.contact__heading {
  font-family: var(--font-sans);
  font-weight: 200;
  font-size: var(--fs-h2);
  letter-spacing: -0.02em;
  color: var(--white);
  line-height: 1.15;
  margin-bottom: 1.2rem;
}

.contact__sub {
  font-size: 0.8rem;
  font-weight: 300;
  color: var(--ash);
  line-height: 1.9;
  max-width: 340px;
}

.contact__methods {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.contact-method {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  padding: 1.4rem 1.6rem;
  border: 1px solid var(--stone);
  transition: border-color 0.3s, background 0.3s;
  position: relative;
  overflow: hidden;
}

.contact-method::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 0;
  background: var(--brass-dark);
  transition: width 0.4s var(--ease-smooth);
  opacity: 0.3;
}

.contact-method:hover {
  border-color: var(--brass-dim);
  background: var(--charcoal);
}

.contact-method:hover::before {
  width: 3px;
}

.contact-method__label {
  font-family: var(--font-mono);
  font-size: 0.5rem;
  letter-spacing: var(--track-xl);
  color: var(--brass-dim);
  text-transform: uppercase;
}

.contact-method__value {
  font-size: 0.88rem;
  font-weight: 300;
  color: var(--linen);
  letter-spacing: 0.03em;
}

.contact-method__note {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  color: var(--ash);
  letter-spacing: 0.06em;
}

/* ── FOOTER ── */
.footer {
  padding: 1.8rem var(--pad-x);
  border-top: 1px solid var(--stone);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.75rem;
  max-width: 100%;
}

.footer__copy {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  color: var(--ash);
  text-transform: uppercase;
}

.footer__note {
  font-family: var(--font-mono);
  font-size: 0.54rem;
  letter-spacing: 0.06em;
  color: var(--stone);
  text-transform: uppercase;
}

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(22px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.4; transform: scale(0.6); }
}

/* ── REVEAL ON SCROLL ── */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.9s var(--ease-smooth), transform 0.9s var(--ease-smooth);
}

.reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.reveal--delay-1 { transition-delay: 0.08s; }
.reveal--delay-2 { transition-delay: 0.16s; }
.reveal--delay-3 { transition-delay: 0.24s; }
.reveal--delay-4 { transition-delay: 0.32s; }

/* hero entry animations — no class needed, pure CSS */
.hero__eyebrow  { animation: fadeUp 1s var(--ease-out) forwards 0.15s; opacity: 0; }
.hero__headline { animation: fadeUp 1s var(--ease-out) forwards 0.3s;  opacity: 0; }
.hero__body     { animation: fadeUp 1s var(--ease-out) forwards 0.5s;  opacity: 0; }
.hero__actions  { animation: fadeUp 1s var(--ease-out) forwards 0.65s; opacity: 0; }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .services__grid {
    grid-template-columns: 1fr;
  }
  .service-card {
    border-right: none;
    border-bottom: 1px solid var(--stone);
  }
  .service-card:last-child { border-bottom: none; }
  .about__inner {
    grid-template-columns: 1fr;
  }
  .about__left { position: static; }
  .contact__inner {
    grid-template-columns: 1fr;
  }
  .nav__links { gap: 1.5rem; }
}

@media (max-width: 600px) {
  .nav__link:not(.nav__link--cta) { display: none; }
  .hero__headline { letter-spacing: -0.01em; }
}

/* ── SELECTION ── */
::selection {
  background: var(--brass);
  color: var(--black);
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--black); }
::-webkit-scrollbar-thumb { background: var(--stone); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: var(--ash); }
